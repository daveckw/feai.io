---

---

<!-- Team Section -->
<section id="team-section" class="py-20 lg:py-20 bg-white overflow-hidden">
    <!-- Main Container -->
    <div class="max-w-5xl mx-auto px-8 lg:px-16">
        <!-- Section A: Why Choose FEAI -->
        <div
            class="flex flex-col lg:flex-row gap-6 lg:gap-40 items-center justify-center"
        >
            <!-- Left Content -->
            <div class="space-y-5 animate-on-scroll">
                <!-- Section Label -->
                <span class="text-blue-500 text-sm font-medium">
                    Why Choose FEAI
                </span>

                <!-- Headline -->
                <h2 class="text-3xl md:text-4xl font-bold leading-tight text-gray-900 tracking-tight">
                    Experts Behind<br />Your AI Success
                </h2>

                <!-- Subtext -->
                <p class="text-gray-500 text-sm leading-relaxed max-w-md">
                    We do not just provide tools. We build, configure, and
                    manage your entire AI system, tailored to your business
                    needs with continuous optimization and expert support.
                </p>

                <!-- Button -->
                <div class="pt-2">
                    <a
                        href="https://wa.me/601171896865?text=Hi%2C%20I'd%20like%20to%20schedule%20a%20free%20consultation"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center justify-center px-6 py-3 bg-gray-900 text-white text-sm font-medium rounded-full hover:bg-gray-800 transition-colors duration-200"
                    >
                        Schedule a Free Consultation
                    </a>
                </div>
            </div>

            <!-- Right Content (Image) -->
            <div
                class="relative flex justify-center lg:justify-end animate-on-scroll stagger-2"
            >
                <img
                    src="/images/ai-globe-nobg.png"
                    alt="FEAI AI Globe"
                    class="w-64 h-64 lg:w-80 lg:h-80 object-contain"
                />
            </div>
        </div>

        <!-- Section B: Team Members -->
        <div
            class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 mt-8 pt-8"
        >
            <!-- Name Card 1: Cardee Chang -->
            <div
                class="bg-slate-50 border border-gray-300 rounded-xl flex flex-row overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300 min-h-[260px] animate-on-scroll stagger-1"
            >
                <div class="flex-[1.62] min-w-0 pl-6 sm:pl-8 pr-4 pt-8 pb-8 flex flex-col justify-start">
                    <h3 class="font-bold text-gray-900 text-lg sm:text-xl mb-0.5">
                        Cardee Chang
                    </h3>
                    <p class="text-gray-500 font-medium text-xs sm:text-sm mb-4">
                        Founder & CEO
                    </p>
                    <div class="text-gray-600 text-xs leading-relaxed space-y-2">
                        <p class="font-semibold text-gray-800">
                            8 years' experience in AI & Automation
                        </p>
                        <p class="text-gray-500">
                            Hands-on practitioner applying AI to sales & marketing
                        </p>
                    </div>
                </div>
                <div class="w-[38%] flex-shrink-0 min-h-[260px] overflow-hidden">
                    <img
                        src="/team_images/Cardee_Chang.jpg"
                        alt="Cardee Chang"
                        class="w-full h-full object-cover"
                        style="object-position: 100% 100%;"
                    />
                </div>
            </div>

            <!-- Name Card 2: Michael Jau -->
            <div
                class="bg-slate-50 border border-gray-300 rounded-xl flex flex-row overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300 min-h-[260px] animate-on-scroll stagger-1"
            >
                <div class="flex-[1.62] min-w-0 pl-6 sm:pl-8 pr-4 pt-8 pb-8 flex flex-col justify-start">
                    <h3 class="font-bold text-gray-900 text-lg sm:text-xl mb-0.5">
                        Michael Jau
                    </h3>
                    <p class="text-gray-500 font-medium text-xs sm:text-sm mb-4">
                        Co-Founder & COO
                    </p>
                    <div class="text-gray-600 text-xs leading-relaxed space-y-2">
                        <p class="font-semibold text-gray-800">
                            15 years' experience in Financial Services
                        </p>
                        <p class="text-gray-500">
                            Led the first insurance agency & mortgage advisory to apply AI in standardized SOPs and client CRM
                        </p>
                    </div>
                </div>
                <div class="w-[38%] flex-shrink-0 min-h-[260px] overflow-hidden">
                    <img
                        src="/team_images/Michael_Jau.jpg"
                        alt="Michael Jau"
                        class="w-full h-full object-cover"
                        style="object-position: 0% 100%;"
                    />
                </div>
            </div>

            <!-- Name Card 3: Technical Team -->
            <div
                class="md:col-span-2 bg-slate-50 border border-gray-300 rounded-xl flex flex-col sm:flex-row overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300 min-h-[200px] animate-on-scroll stagger-2"
            >
                <div class="flex-[2] min-w-0 pl-6 sm:pl-8 pr-4 pt-8 pb-8 flex flex-col justify-start">
                    <h3 class="font-bold text-gray-900 text-lg sm:text-xl mb-4">
                        Technical Team
                    </h3>
                    <div class="text-gray-600 text-xs leading-relaxed space-y-2">
                        <p class="font-semibold text-gray-800">
                            8 years' experience in AI Systems & Automation
                        </p>
                        <p class="text-gray-500">
                            A dedicated engineering team with deep expertise in conversational AI architecture, system integrations, and data engineering
                        </p>
                    </div>
                </div>
                <div class="sm:w-[38%] flex-shrink-0 h-40 sm:h-[200px] overflow-hidden flex items-start">
                    <img
                        src="/team_images/feai_team.jpg"
                        alt="FEAI Technical Team"
                        class="w-full h-full object-cover"
                        style="object-position: center 40%;"
                    />
                </div>
            </div>
        </div>
    </div>
</section>
