---
---
<!-- Section: Feature Highlights -->
<section id="features" class="py-20 lg:py-20 bg-white overflow-hidden">
    <div class="max-w-5xl mx-auto px-8 lg:px-16">
        <!-- Section Header (styling aligned with Team / other sections) -->
        <div
            class="mb-12 md:mb-16 space-y-5 max-w-5xl"
        >
            <span class="text-blue-500 text-sm font-medium">
                Feature Highlights
            </span>
            <h2
                class="text-3xl md:text-4xl font-bold leading-tight text-gray-900 tracking-tight"
            >
                Designed to Automate More
            </h2>
            <p class="text-gray-500 text-sm leading-relaxed">
                We go beyond simple text replies. Explore the advanced
                capabilities that make our AI feel like a true extension of
                your team.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
            <!-- Feature 1: Poll-Triggered Automation -->
            <div
                class="bg-slate-50 rounded-xl p-8 border border-gray-300 flex flex-col h-full"
            >
                <h3 class="font-bold text-gray-900 text-lg sm:text-xl mb-3">
                    Poll-Triggered Automation
                </h3>

                <p class="text-gray-500 text-xs leading-relaxed mb-3 flex-grow">
                    Automatically trigger replies, follow-ups, and workflows when a user selects a poll option.
                </p>

                <div
                    class="w-full h-[20rem] flex items-center justify-center mt-auto"
                >
                    <div
                        class="w-[44%] h-full overflow-hidden"
                    >
                        <img
                            src="/sample_images/Sample1_AutoReply_ClickPoll.jpg"
                            alt="WhatsApp poll response triggering automated workflow"
                            class="w-full h-full object-cover object-[center_55%]"
                        />
                    </div>
                </div>
            </div>

            <!-- Feature 2: Voice Message Intelligence -->
            <div
                class="bg-slate-50 rounded-xl p-8 border border-gray-300 flex flex-col h-full"
            >
                <h3 class="font-bold text-gray-900 text-lg sm:text-xl mb-3">
                    Voice Message Intelligence
                </h3>

                <p class="text-gray-500 text-xs leading-relaxed mb-6 flex-grow">
                    Understand and interpret voice messages accurately, enabling seamless conversations without text input.
                </p>

                <div
                    class="w-full h-[20rem] flex items-center justify-center mt-auto"
                >
                    <div
                        class="w-[44%] h-full overflow-hidden"
                    >
                        <img
                            src="/sample_images/Sample2_AutoReply_TraceSound.jpg"
                            alt="WhatsApp voice message analyzed by AI for automated response"
                            class="w-full h-full object-cover object-[center_55%]"
                        />
                    </div>
                </div>
            </div>

            <!-- Feature 3: Sample Flow -->
            <div
                class="bg-slate-50 rounded-xl p-8 border border-gray-300 flex flex-col h-full"
            >
                <h3 class="font-bold text-gray-900 text-lg sm:text-xl mb-3">
                    Custom Workflows
                </h3>
                <p
                    class="text-gray-500 text-xs leading-relaxed mb-6 flex-grow"
                >
                    Automate the mundane. We build hybrid workflows
                    combining AI intelligence with traditional automation.
                </p>

                <!-- Step 1: Outer = pure space (same for all features). Fixed height. -->
                <div
                    class="w-full h-full flex items-center justify-center mt-auto"
                >
                    <!-- Step 2: Inner = image container. -->
                    <div
                        class="w-full h-[16rem] overflow-hidden"
                    >
                        <img
                            src="/sample_images/Sample3_SampleFlow.jpg"
                            alt="Custom Workflow"
                            class="w-full h-full object-cover object-center"
                        />
                    </div>
                </div>
            </div>

            <!-- Feature 4: Multi Language Support -->
            <div
                class="bg-slate-50 rounded-xl p-8 border border-gray-300 flex flex-col h-full"
            >
                <h3 class="font-bold text-gray-900 text-lg sm:text-xl mb-3">
                    Global Multi-Language
                </h3>
                <p
                    class="text-gray-500 text-xs leading-relaxed mb-6 flex-grow"
                >
                    Break down language barriers. Support and reply to
                    customers instantly across multiple languages.
                </p>

                <!-- Step 1: Outer = pure space (same for all features). Fixed height. -->
                <div
                    class="w-full h-[16rem] flex items-center justify-center mt-auto"
                >
                    <!-- Step 2: Inner = image container. -->
                    <div
                        class="w-ful h-[12rem] overflow-hidden"
                    >
                        <img
                            src="/sample_images/Sample4_MultiLanguage.png"
                            alt="Multi-Language Support"
                            class="w-full h-full object-cover object-center"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
